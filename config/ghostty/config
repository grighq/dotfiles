# Shaders
custom-shader = ~/.config/ghostty/shaders/cursor_warp.glsl

# Ui
font-size = 13
font-family = Maple Mono

scrollbar = never
cursor-style = bar
adjust-box-thickness = 1
cursor-style-blink = false
adjust-cursor-thickness = 1
window-padding-balance = true

# Gtk
gtk-wide-tabs = false
gtk-single-instance = true
gtk-tabs-location = hidden
gtk-custom-css = ghostty.css

# Terminal features
link-url = false
mouse-hide-while-typing = true
notify-on-command-finish = unfocused
app-notifications = no-clipboard-copy,no-config-reload

# Keybinds
# Disable default toggle_fullscreen(needed for zsh vi mode command)
# Disable all default keybinds
keybind = clear

# Use shift+space as prefix for most ghostty commands
keybind = shift+space>t=new_tab
keybind = shift+space>q=close_surface
keybind = shift+space>w=close_tab:this
keybind = shift+space>v=paste_from_clipboard

keybind = shift+space>ctrl+v=new_split:right
keybind = shift+space>ctrl+s=new_split:down
keybind = shift+space>ctrl+j=goto_split:down
keybind = shift+space>ctrl+k=goto_split:up
keybind = shift+space>ctrl+l=goto_split:right
keybind = shift+space>ctrl+h=goto_split:left


keybind = ctrl+tab=next_tab
keybind = ctrl+shift+tab=previous_tab
keybind = super+o=toggle_tab_overview

keybind = shift+space>i=inspector:toggle
keybind = shift+space>p=toggle_command_palette

keybind = shift+space>f=start_search
keybind = shift+space>r=reload_config


# Open scroll file in nvim. Disable this when fixed write_screen_file:open,plain
keybind = shift+space>[=text:v\x20
keybind = chain=write_screen_file:paste,plain
keybind = chain=text:\r

theme = TokyoNight Moon
